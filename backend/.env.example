# =============================
# Sea Tracker Backend Settings
# Copy this file to backend/.env and fill in values as needed.
# =============================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/seatracker
DATABASE_SYNC_URL=postgresql://postgres:yourpassword@localhost:5432/seatracker

# Redis
REDIS_URL=redis://localhost:6379

# AIS / Ocean Data Sources
AISSTREAM_API_KEY=replace_with_aisstream_api_key
AISSTREAM_IDLE_RESTART_SECONDS=90
AISSTREAM_PROBE_TIMEOUT_SECONDS=15
AISSTREAM_MAX_RECONNECT_SECONDS=120
GFW_API_KEY=
CMEMS_USERNAME=
CMEMS_PASSWORD=

# Vessel tracking and retention
VESSEL_TIMEOUT_MINUTES=30
LIVE_FEED_WINDOW_MINUTES=5.0
SOURCE_STALE_SECONDS=180
HISTORY_RETENTION_DAYS=30
COLLISION_ALERT_DISTANCE_NM=2.0

# Alerts / notification behavior
ALERT_SOUND_ENABLED=true
VESSEL_DARK_MINUTES=5

# SMTP notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Polling intervals (seconds)
NOAA_POLL_INTERVAL=60
GFW_POLL_INTERVAL=300
WEATHER_POLL_INTERVAL=900
OCEAN_POLL_INTERVAL=3600
TIDE_POLL_INTERVAL=1800
PORT_REFRESH_INTERVAL=604800

# Server
HOST=0.0.0.0
PORT=8000
# For list values, use JSON array format
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
